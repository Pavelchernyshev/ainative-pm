{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Worth Building — brand core design tokens. Acid chartreuse on near-black, Brunson display + Perfectly Nineties serif.",
  "color": {
    "$type": "color",
    "acid": {
      "$description": "Primary brand ramp. Base = acid-500 (#7FFF00). Only acid-800/900 are safe as text on light backgrounds.",
      "50":  { "$value": "#F2FFDE" },
      "100": { "$value": "#E4FFBD" },
      "200": { "$value": "#CCFF85" },
      "300": { "$value": "#B0FF4D" },
      "400": { "$value": "#97FF1A" },
      "500": { "$value": "#7FFF00" },
      "600": { "$value": "#6BD900" },
      "700": { "$value": "#54AB00" },
      "800": { "$value": "#3D7D00" },
      "900": { "$value": "#294F00" }
    },
    "ink": {
      "$description": "Neutral ramp. Base black = ink-800 (#1A1A1A).",
      "0":   { "$value": "#FFFFFF" },
      "50":  { "$value": "#F5F5F4" },
      "100": { "$value": "#E7E7E5" },
      "200": { "$value": "#C9C9C6" },
      "300": { "$value": "#A3A3A0" },
      "400": { "$value": "#6E6E6B" },
      "500": { "$value": "#4A4A48" },
      "600": { "$value": "#333331" },
      "700": { "$value": "#262625" },
      "800": { "$value": "#1A1A1A" },
      "900": { "$value": "#0D0D0D" }
    }
  },
  "semantic": {
    "$type": "color",
    "background": {
      "default":  { "$value": "{color.ink.800}", "$description": "App/brand default surface — near-black." },
      "raised":   { "$value": "{color.ink.700}" },
      "sunken":   { "$value": "{color.ink.900}" },
      "inverse":  { "$value": "{color.ink.0}" },
      "brand":    { "$value": "{color.acid.500}", "$description": "Acid fill. Pair only with ink-800 text." }
    },
    "text": {
      "primary":   { "$value": "{color.ink.0}",   "$description": "On dark surfaces. 17.4:1 on ink-800 (AAA)." },
      "secondary": { "$value": "{color.ink.300}", "$description": "Muted on dark. 6.88:1 on ink-800 (AA)." },
      "onBrand":   { "$value": "{color.ink.800}", "$description": "Text on acid-500. 13.43:1 (AAA)." },
      "onLight":   { "$value": "{color.ink.800}", "$description": "Primary text on light surfaces. 17.4:1 on white (AAA)." },
      "brandOnLight": { "$value": "{color.acid.900}", "$description": "Green text usable on light. 9.49:1 on white (AAA). Never use acid-500 as text on light." },
      "accent":    { "$value": "{color.acid.500}", "$description": "Accent/link text on dark only. 13.43:1 on ink-800 (AAA)." }
    },
    "border": {
      "subtle":  { "$value": "{color.ink.600}" },
      "default": { "$value": "{color.ink.500}" },
      "focus":   { "$value": "{color.acid.500}" }
    },
    "interactive": {
      "primary":        { "$value": "{color.acid.500}" },
      "primaryHover":   { "$value": "{color.acid.400}" },
      "primaryActive":  { "$value": "{color.acid.600}" },
      "primaryText":    { "$value": "{color.ink.800}" }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": ["Brunson", "Arial Narrow", "Helvetica Neue", "sans-serif"], "$description": "Bold condensed display — headlines, logo lockups. Set uppercase for hero moments." },
      "serif":   { "$value": ["Perfectly Nineties", "Georgia", "Times New Roman", "serif"], "$description": "Body copy, quotes, editorial lead-ins." },
      "mono":    { "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$description": "Timestamps, metadata, code." }
    },
    "weight": {
      "$type": "number",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "bold":     { "$value": 700 },
      "black":    { "$value": 800 }
    }
  },
  "typography": {
    "$type": "typography",
    "displayXxl": { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 800, "fontSize": "6rem",    "lineHeight": "0.95", "letterSpacing": "-0.02em", "textTransform": "uppercase" } },
    "displayXl":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 800, "fontSize": "4.5rem",  "lineHeight": "0.96", "letterSpacing": "-0.02em", "textTransform": "uppercase" } },
    "displayLg":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 800, "fontSize": "3.5rem",  "lineHeight": "1.0",  "letterSpacing": "-0.015em", "textTransform": "uppercase" } },
    "displayMd":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 700, "fontSize": "2.5rem",  "lineHeight": "1.05", "letterSpacing": "-0.01em" } },
    "headingLg":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 700, "fontSize": "2rem",    "lineHeight": "1.1",  "letterSpacing": "-0.01em" } },
    "headingMd":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 700, "fontSize": "1.5rem",  "lineHeight": "1.15", "letterSpacing": "0" } },
    "headingSm":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": 700, "fontSize": "1.25rem", "lineHeight": "1.2",  "letterSpacing": "0" } },
    "lead":       { "$value": { "fontFamily": "{font.family.serif}",   "fontWeight": 400, "fontSize": "1.5rem",  "lineHeight": "1.5",  "letterSpacing": "0", "fontStyle": "italic" } },
    "bodyLg":     { "$value": { "fontFamily": "{font.family.serif}",   "fontWeight": 400, "fontSize": "1.25rem", "lineHeight": "1.6",  "letterSpacing": "0" } },
    "bodyMd":     { "$value": { "fontFamily": "{font.family.serif}",   "fontWeight": 400, "fontSize": "1rem",    "lineHeight": "1.6",  "letterSpacing": "0" } },
    "bodySm":     { "$value": { "fontFamily": "{font.family.serif}",   "fontWeight": 400, "fontSize": "0.875rem","lineHeight": "1.55", "letterSpacing": "0" } },
    "caption":    { "$value": { "fontFamily": "{font.family.mono}",    "fontWeight": 400, "fontSize": "0.75rem", "lineHeight": "1.4",  "letterSpacing": "0.04em", "textTransform": "uppercase" } }
  },
  "space": {
    "$type": "dimension",
    "0":  { "$value": "0" },
    "1":  { "$value": "0.25rem" },
    "2":  { "$value": "0.5rem" },
    "3":  { "$value": "0.75rem" },
    "4":  { "$value": "1rem" },
    "5":  { "$value": "1.5rem" },
    "6":  { "$value": "2rem" },
    "7":  { "$value": "2.5rem" },
    "8":  { "$value": "3rem" },
    "9":  { "$value": "4rem" },
    "10": { "$value": "5rem" },
    "11": { "$value": "6rem" },
    "12": { "$value": "8rem" }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0" },
    "sm":   { "$value": "0.25rem" },
    "md":   { "$value": "0.5rem" },
    "lg":   { "$value": "1rem" },
    "xl":   { "$value": "1.5rem" },
    "pill": { "$value": "999px" }
  },
  "elevation": {
    "$type": "shadow",
    "none": { "$value": "none" },
    "sm":   { "$value": { "offsetX": "0", "offsetY": "1px",  "blur": "2px",  "spread": "0", "color": "rgba(0,0,0,0.40)" } },
    "md":   { "$value": { "offsetX": "0", "offsetY": "4px",  "blur": "12px", "spread": "0", "color": "rgba(0,0,0,0.45)" } },
    "lg":   { "$value": { "offsetX": "0", "offsetY": "12px", "blur": "32px", "spread": "0", "color": "rgba(0,0,0,0.50)" } },
    "glow": { "$value": { "offsetX": "0", "offsetY": "0",    "blur": "24px", "spread": "0", "color": "rgba(127,255,0,0.45)" }, "$description": "Acid glow for hero/CTA emphasis on dark." }
  }
}
